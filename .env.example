# ============================================================
# Eshow（易修）— 环境变量配置模板
# 复制为 .env 并填入实际值
# 正式部署用 .env（正式 Bot）；联调/测试 Bot 见 .env.test。勿提交含密钥的文件
# 变量顺序与 backend/config.py 中 Settings 一致
# ============================================================

# ---- 通用应用设置 ----
# APP_NAME=Eshow Backend
# APP_VERSION=0.1.0
DEBUG=false
ENVIRONMENT=production
SECRET_KEY=CHANGE_ME
API_KEY=

# ---- 服务及网络设置 ----
HOST=0.0.0.0
PORT=8000
# CORS_ORIGINS、ALLOWED_HOSTS 留空则使用 config 默认值；列表格式见 pydantic-settings 文档
PAYMENT_CALLBACK_URL=https://your-domain.com/api/payments/callback
PAYMENT_CALLBACK_RATE_LIMIT_PER_MINUTE=120

# ---- 数据库（与 docker-compose.yml 中 db 服务默认值一致）----
POSTGRES_USER=eshow
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=eshow
POSTGRES_PORT=5432
# 宿主机连本机 Postgres（compose 端口映射默认 5432）；容器内 app 服务由 compose 注入 DATABASE_URL（主机名为 db）
DATABASE_URL=postgresql+asyncpg://eshow:CHANGE_ME@localhost:5432/eshow

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=

# ---- 支付宝 ----
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# ---- 微信 ----
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
WECHAT_API_V3_KEY=
WECHAT_PLATFORM_CERT_PEM=

# ---- USDT (TRC20)（留空则不启用链上监控）----
TRC20_WALLET_ADDRESS=
TRC20_CHECK_INTERVAL=15
TRC20_ORDER_TIMEOUT_MINUTES=15
TRC20_PENDING_SCAN_BATCH_SIZE=200
TRC20_PENDING_SCAN_MAX_BATCHES=100

# ---- 汇率 ----
EXCHANGE_RATE_API_KEY=

# ---- Celery Worker ----
# 本地 Redis 示例：redis://localhost:6379/0；留空则 API 创建任务后不入队（仅告警日志）
CELERY_BROKER_URL=
# CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- RunningHub 轮询终态（无公网 Webhook 时主路径）----
# 须显式设置 CELERY_BROKER_URL 才会注册 Beat 的 poll_schedule；并运行 celery_beat + worker_poll（maintenance）
# POLL_ENABLED=true 时：poll_schedule → tasks.poll_terminal
POLL_ENABLED=false
POLL_INTERVAL_SEC=60
POLL_BATCH_SIZE=30
# 单 tick 内并发 query_task 上限（1=串行）；增大可缩短尾延迟，易触发 RH 限流
POLL_MAX_CONCURRENT=1
# running 超过此时长（秒）仍无终态则标 failed（poll_running_timeout）并释槽/解冻；默认 7200=2h
POLL_MAX_RUNNING_SEC=7200

# ---- 本地文件存储（临时中转，定期清理）----
UPLOAD_DIR=data/uploads
UPLOAD_RETAIN_DAYS=3

# ---- RunningHub ----
RUNNINGHUB_API_KEY=
RUNNINGHUB_BASE_URL=https://www.runninghub.cn
RUNNINGHUB_WEBHOOK_PUBLIC_BASE_URL=

# ---- 算力「创建运行」提交前并发槽 ----
# 留空则与 CELERY_BROKER_URL 共用同一 Redis；键前缀 eshow:slot:
SLOT_REDIS_URL=
SLOT_MAX_CONCURRENT_GLOBAL=32
SLOT_MAX_CONCURRENT_PER_USER=6

# ---- 仅 Compose / 其他进程 ----
REDIS_PORT=6379
# Telegram Bot 调本机 FastAPI（与 API_KEY 一致）
BACKEND_BASE_URL=http://127.0.0.1:8000
# BACKEND_HTTP_CONNECT_TIMEOUT=5
# BACKEND_HTTP_READ_TIMEOUT=30
# 独立跑 Bot 时至少需 TELEGRAM_BOT_TOKEN、BACKEND_BASE_URL；生产建议同时配置 API_KEY。
