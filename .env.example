# ============================================================
# TG Payment Bot - 环境变量配置模板
# 复制为 .env 并填入实际值
# ============================================================

# --- 基础 ---
DEBUG=false
ENVIRONMENT=production

# --- 数据库 (Docker Compose 会自动拼接 DATABASE_URL) ---
POSTGRES_USER=tgbot
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=tg_payment_bot
# 独立部署时手动设置:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/tg_payment_bot

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=

# --- API 鉴权 (留空则跳过鉴权，仅开发用) ---
API_KEY=

# --- TRC20 USDT (留空则不启用链上监控) ---
TRC20_WALLET_ADDRESS=
TRC20_CHECK_INTERVAL=15
TRC20_ORDER_TIMEOUT_MINUTES=15

# --- 支付宝 ---
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=

# --- 微信支付 ---
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
# V3 回调：32 字节 APIv3 密钥（解密 resource）；平台公钥证书 PEM（验签）
WECHAT_API_V3_KEY=
WECHAT_PLATFORM_CERT_PEM=

# TRC20 监控：pending 订单 keyset 扫描（每批条数 / 每 tick 最多批次数）
TRC20_PENDING_SCAN_BATCH_SIZE=200
TRC20_PENDING_SCAN_MAX_BATCHES=100

# 支付回调按 IP 限流（次/分钟，0 表示关闭）
PAYMENT_CALLBACK_RATE_LIMIT_PER_MINUTE=120

# --- 其他 ---
SECRET_KEY=CHANGE_ME
PAYMENT_CALLBACK_URL=https://your-domain.com/api/payments/callback
HOST=0.0.0.0
PORT=8000
